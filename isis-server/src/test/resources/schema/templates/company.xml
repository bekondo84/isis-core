<?xml version="1.0" encoding="UTF-8" ?>
<context xmlns="http://www.isis.cm/config/isis-template"
         xmlns:ls="http://www.isis.cm/config/list-view"
         xmlns:a="http://www.isis.cm/config/isis-actions"
         xmlns:e="http://www.isis.cm/config/editor-area">
    <ls:list-view>
        <ls:list>
            <ls:column qualifier="logo" search="false"  widget="media"/>
            <ls:column qualifier="code" search="true" />
            <ls:column qualifier="name" search="false"  widget="localized"/>
            <ls:column qualifier="nui" search="true" />
            <ls:column qualifier="adresse" search="true" />
            <ls:column qualifier="town" search="true" show="false"/>
            <ls:column qualifier="country" search="true" show="false"/>
            <ls:column qualifier="postal" search="true" show="false"/>
            <ls:column qualifier="slogan" search="true" show="false" widget="localized"/>
            <ls:column qualifier="website" search="true" show="false"/>
            <ls:column qualifier="phone" search="true" show="false"/>
            <ls:column qualifier="fax" search="true" show="false"/>
            <ls:column qualifier="email" search="true" show="false"/>
        </ls:list>
        <a:actions>
            <a:action name="cronJob.start.action" code="cronJob.start.action" icon="fa-regular fa-circle-play" position="workflow"/>
            <a:action name="cronJob.stop.action" code="cronJob.stop.action" icon="fa-regular fa-circle-stop" position="workflow"/>
        </a:actions>
        <ls:kanban>
            <ls:template>
                Test HTML ICI POUR LE KABAN
            </ls:template>
        </ls:kanban>
    </ls:list-view>
    <e:editor-area searchKey="code" createOnField="false" >
        <e:component>
            <e:common>
                <e:form>
                    <e:section name="hac.commons" columns="2" position="100">
                        <e:section name="hac.commons-001" position="100" columns="1">
                            <e:field qualifier="logo" widget="media" />
                        </e:section>
                        <e:section name="hac.commons-002" position="99" columns="1">
                            <e:field qualifier="code" >
                                <e:filters>
                                    <e:filter source="nui" operator="eq" value="1000" />
                                </e:filters>
                            </e:field>
                            <e:field qualifier="nui" />
                        </e:section>
                    </e:section>
                    <e:section name="hac.commons" columns="2" position="99">
                        <e:field qualifier="name" widget="localized" />
                        <e:field qualifier="slogan" widget="localized" />
                    </e:section>
                    <e:section name="hac.commons" columns="2" position="98">
                        <e:section name="hac.commons-001" columns="1" position="100">
                            <e:field qualifier="adresse" />
                            <e:field qualifier="country" />
                            <e:field qualifier="town" />
                            <e:field qualifier="postal" />
                        </e:section>
                        <e:section name="hac.commons-002" columns="1" position="100">
                            <e:field qualifier="website" />
                            <e:field qualifier="phone" />
                            <e:field qualifier="fax" />
                            <e:field qualifier="email" />
                        </e:section>
                    </e:section>
                </e:form>
            </e:common>
            <e:tab name="tab01">
                <e:form>
                    <e:section name="tab01.section01">
                        <e:field qualifier="name" />
                        <e:field qualifier="country" />
                    </e:section>
                </e:form>
            </e:tab>
            <e:tab name="tab02">
                <e:form>
                    <e:section name="tab02.section02">
                        <e:field qualifier="name" />
                        <e:field qualifier="country" />
                    </e:section>
                </e:form>
            </e:tab>
        </e:component>
        <a:actions>
            <a:action name="cronJob.start.action" code="cronJob.start.action" icon="fa-regular fa-circle-play" position="workflow"/>
            <a:action name="cronJob.stop.action" code="cronJob.stop.action" icon="fa-regular fa-circle-stop" position="workflow"/>
        </a:actions>
    </e:editor-area>
</context>